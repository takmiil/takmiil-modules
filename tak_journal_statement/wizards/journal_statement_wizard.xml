<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_journal_statement_wizard_form" model="ir.ui.view">
        <field name="name">journal.statement.wizard.form</field>
        <field name="model">journal.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Journal Statement">
                <sheet>
                    <group>
                        <group>
                            <field name="date_from"/>
                            <field name="journal_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit': True}"/>
                        </group>
                        <group>
                            <field name="date_to"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report" string="View" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_journal_statement_wizard" model="ir.actions.act_window">
        <field name="name">Journal Statement</field>
        <field name="res_model">journal.statement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_journal"/>
        <field name="binding_view_types">list,form</field>
    </record>


    <menuitem id="journal_statement_wizard_menu" name="Journal Statement" action="action_journal_statement_wizard" groups="account.group_account_invoice" parent="account.account_reports_legal_statements_menu" sequence="19" />
</odoo>