<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- FORM VIEW -->
    <!-- ============================================ -->
    <record id="view_tak_journal_transfer_form" model="ir.ui.view">
        <field name="name">tak.journal.transfer.form</field>
        <field name="model">tak.journal.transfer</field>
        <field name="arch" type="xml">
            <form string="Journal Transfer">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                        class="oe_highlight" invisible="state != 'draft'"
                        confirm="Are you sure you want to execute this transfer?" />

                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                        invisible="state != 'posted'"
                        confirm="This will Delete the journal entries. Continue?" />

                    <button name="action_cancel" string="Cancel" type="object"
                        invisible="state not in ('draft')" class="btn-secondary" />
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,posted,cancelled" />
                </header>
                <sheet>
                    <!-- Smart Button Box -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_moves" type="object" 
                            class="oe_stat_button" icon="fa-book"
                            invisible="move_count == 0">
                            <field name="move_count" widget="statinfo" string="Entries"/>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state in ['cancelled', 'posted']" />
                            <field name="amount" readonly="state in ['cancelled', 'posted']"/>
                            <field name="company_id" groups="base.group_multi_company" />
                            <field name="currency_id" invisible="1" />
                            <field name="company_currency_id" invisible="1" />
                        </group>
                        <group>
                            <table style="width: 100%;">
                                <tr>
                                    <td style="width: 50px; padding: 4px 0;">
                                        <strong>From:</strong>
                                    </td>
                                    <td style="padding: 4px 8px;">
                                        <field name="source_journal_id"
                                            readonly="state in ['cancelled', 'posted']" />
                                    </td>
                                    <td style="padding: 4px 0;">
                                        <field name="source_balance" readonly="1" widget="monetary" />
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 4px 0;">
                                        <strong>To:</strong>
                                    </td>
                                    <td style="padding: 4px 8px;">
                                        <field name="destination_journal_id"
                                            readonly="state in ['cancelled', 'posted']" />
                                    </td>
                                    <td style="padding: 4px 0;">
                                        <field name="destination_balance" readonly="1"
                                            widget="monetary" />
                                    </td>
                                </tr>
                            </table>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notes">
                            <group >
                                <field name="notes" readonly="state in ['cancelled', 'posted']" placeholder="Description for journal entries..."/>
                            </group>
                        </page>

                        <page string="MISC.">
                            <group name="misc" string="Misc">
                                <field name="create_uid" readonly="1" placeholder="Created by"/>
                                <field name="is_reconciled" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    
    <!-- ============================================ -->
    <!-- LIST VIEW -->
    <!-- ============================================ -->
    <record id="view_tak_journal_transfer_list" model="ir.ui.view">
        <field name="name">tak.journal.transfer.list</field>
        <field name="model">tak.journal.transfer</field>
        <field name="arch" type="xml">
            <list string="Journal Transfers" decoration-muted="state == 'cancelled'"
                decoration-success="state == 'posted'" decoration-info="state == 'draft'" default_order="id desc,name desc">
                <field name="name" />
                <field name="date" />
                <field name="source_journal_id" />
                <field name="destination_journal_id" />
                <field name="amount" sum="Total" />
                <field name="state" widget="badge" decoration-success="state == 'posted'"
                    decoration-info="state == 'draft'" decoration-muted="state == 'cancelled'" />
            </list>
        </field>
    </record>
    
    <!-- ============================================ -->
    <!-- SEARCH VIEW -->
    <!-- ============================================ -->
    <record id="view_tak_journal_transfer_search" model="ir.ui.view">
        <field name="name">tak.journal.transfer.search</field>
        <field name="model">tak.journal.transfer</field>
        <field name="arch" type="xml">
            <search string="Journal Transfers">
                <field name="name" />
                <field name="source_journal_id" />
                <field name="destination_journal_id" />
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]" />
                <filter name="posted" string="posted" domain="[('state', '=', 'posted')]" />
                <filter name="cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]" />
                <group string="Group By" expand="0">
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}" />
                    <filter name="group_by_source" string="Source Journal"
                        context="{'group_by': 'source_journal_id'}" />
                    <filter name="group_by_destination" string="Destination Journal"
                        context="{'group_by': 'destination_journal_id'}" />
                    <filter name="group_by_date" string="Date" context="{'group_by': 'date'}" />
                </group>
            </search>
        </field>
    </record>
    
    <!-- ============================================ -->
    <!-- ACTIONS & MENUS -->
    <!-- ============================================ -->
    <record id="action_tak_journal_transfer" model="ir.actions.act_window">
        <field name="name">Journal Transfers</field>
        <field name="res_model">tak.journal.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tak_journal_transfer_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first journal transfer</p>
            <p>Transfer funds between bank and cash journals easily.</p>
        </field>
    </record>
    
    <!-- Menu Item (under taking > Actions) -->
    <menuitem id="menu_tak_journal_transfer_root" name="Journal Transfers"
        action="action_tak_journal_transfer" sequence="150"
        web_icon="tak_journal_transfer,static/description/icon.png"
        groups="tak_journal_transfer.group_journal_transfer_user" />

    <menuitem
        id="menu_tak_journal_transfer_submenu"
        name="Transfer"
        action="action_tak_journal_transfer"
        groups="tak_journal_transfer.group_journal_transfer_user"
        parent="tak_journal_transfer.menu_tak_journal_transfer_root"
        sequence="10" />
</odoo>