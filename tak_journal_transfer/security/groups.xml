<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================ -->
    <!-- CATEGORY -->
    <!-- ============================================ -->
    <record id="module_category_journal_transfer" model="ir.module.category">
        <field name="name">Journal Transfer</field>
        <field name="sequence">50</field>
    </record>


    <record model="res.groups.privilege" id="res_groups_privilege_transfer">
        <field name="name">Journal Transfer</field>
        <field name="category_id" ref="tak_journal_transfer.module_category_journal_transfer"/>
        <field name="sequence">7</field>
    </record>

    <!-- ============================================ -->
    <!-- SECURITY GROUPS -->
    <!-- ============================================ -->

    <!-- User Group: Can create and view own transfers -->
    <record id="group_journal_transfer_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_transfer" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        <field name="comment">Can create transfers and view own records</field>
    </record>

    <!-- Manager Group: Full access to all transfers -->
    <record id="group_journal_transfer_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_transfer" />
        <field name="implied_ids" eval="[(4, ref('group_journal_transfer_user'))]" />
        <field name="comment">Full access to all transfers and configuration</field>
    </record>

    <!-- Administrator Group: Can reset to draft (sensitive operation) -->
    <record id="group_journal_transfer_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="res_groups_privilege_transfer" />
        <field name="implied_ids" eval="[(4, ref('group_journal_transfer_manager'))]" />
        <field name="comment">Can reset transferred entries to draft (accounting reversal)</field>
    </record>

</odoo>