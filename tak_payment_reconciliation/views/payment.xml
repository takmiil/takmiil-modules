<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_reconciliation" model="ir.ui.view">
        <field name="name">Payment Reconciliation </field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">

          
            <!-- Stat button to open the manual reconciliation widget -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_discount_journal_entry" type="object" string="Discount Journal" class="oe_stat_button" icon="fa-money" invisible="not discount_move_id"/>
            </xpath>

            <field name="partner_bank_id" position="after">
                <field name="has_discount" readonly="state != 'draft'"/>
                <field name="customer_discount_product_id" domain="[('customer_discount_product', '=', True)]" invisible="has_discount == False or partner_type == 'supplier'" readonly="state != 'draft'" />
                <field name="vendor_discount_product_id" domain="[('vendor_discount_product', '=', True)]" invisible="has_discount == False  or partner_type == 'customer'" readonly="state != 'draft'" />
                <field name="write_off_amount" invisible="has_discount == False" readonly="state != 'draft'" />
            </field>
            <xpath expr="//form/sheet/group" position="after">
                <notebook invisible="not partner_id">
                    <page string="Invoices / Bills">
                        <header>
                            <button string="Select All" invisible="state == 'paid'" name="select_all" type="object" class="oe_highlight"/>
                            <button string="Deselect All" invisible="state == 'paid'" name="deselect_all" type="object" />
                        </header>
                        <field name="invoice_selection_ids" readonly="state != 'draft'" force_save="1">
                            <list editable="bottom" create="false" delete="false">
                                <field name="selection_disabled" column_invisible="1"></field>
                                <field name="selected" readonly="selection_disabled == True" force_save="1"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="invoice_id" readonly="1" force_save="1"/>
                                <field name="invoice_date" readonly="state != 'draft'"/>
                                <field name="amount_total" sum="Total Amount" readonly="state != 'draft'"/>
                                <field name="amount_due" sum="Total Due" readonly="state != 'draft'"/>
                                <field name="amount_applied" sum="Total Amount Applied" readonly="1"/>
                                <field name="residual" sum="Total Residual" readonly="1"/>
                                <field name="state" widget="badge" decoration-danger="state == 'not_paid'" decoration-warning="state == 'partial'"/>
                            </list>
                            <form>
                                <field name="selected"/>
                                <field name="payment_id" readonly="1" force_save="1"/>
                                <field name="invoice_id" readonly="1" force_save="1"/>
                                <field name="invoice_date"/>
                                <field name="amount_total" />
                                <field name="amount_due" />
                            </form>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>

</odoo>
