<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.payment.discount</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <block id="default_accounts" position="inside">

                <setting string="Default Discount Journal" title="This Will be Used for Discount from Payment Forms">
                    <div class="content-group">
                        <div class="row mt8">
                            <label for="discount_journal_id" class="col-lg-5 o_light_label" string="Default Discount Journal"/>
                            <field name="discount_journal_id" placeholder="Enter Journal"/>
                        </div>
                    </div>
                </setting>

            </block>
        </field>
    </record>
</odoo>