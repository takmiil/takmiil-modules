<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_order_form_inherit_delivery_validation" model="ir.ui.view">
            <field name="name">sale.order.form.inherit.delivery.validation</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button 
                        name="action_validate_all_deliveries" 
                        type="object" 
                        string="Validate Deliveries"
                        class="oe_highlight"
                        invisible="outgoing_picking_count == 0"
                        groups="stock.group_stock_user"
                    />
                </xpath>
                <xpath expr="//field[@name='delivery_status']" position="after">
                    <field name="outgoing_picking_count" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>